ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database connections (optional — agent can also accept connection strings at runtime)
DEFAULT_DB_URL=sqlite:///./data.db
# DEFAULT_DB_URL=postgresql+asyncpg://user:password@localhost:5432/dbname
# DEFAULT_DB_URL=mysql+pymysql://user:password@localhost:3306/dbname

# App settings
BACKEND_PORT=8000
FRONTEND_URL=http://localhost:5173
UPLOAD_DIR=./uploads
REPORTS_DIR=./reports
MAX_UPLOAD_MB=50
